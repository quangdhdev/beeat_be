{
  "name": "@beeat/shared-lib",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "packages/shared-lib/dist",
          "main": "packages/shared-lib/src/index.ts",
          "tsConfig": "packages/shared-lib/tsconfig.lib.json",
          "format": [
            "esm"
          ],
          "declarationRootDir": "packages/shared-lib/src",
          "external": ["@supabase/supabase-js", "@prisma/client", "pino", "zod"],
          "platform": "node"
        }
      }
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.53.0",
    "@prisma/client": "^6.13.0",
    "pino": "^9.7.0",
    "zod": "^4.0.15"
  }
}
